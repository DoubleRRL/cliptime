# SupoClip Environment Configuration
# Copy this file and fill in your API keys

# ==============================================
# AI Provider API Keys (Required for video processing)
# ==============================================

# AssemblyAI - Required for video transcription with word-level timing
ASSEMBLY_AI_API_KEY=

# Choose one AI provider for transcript analysis:
# OpenAI (recommended: gpt-5.2)
OPENAI_API_KEY=

# Google AI (recommended: gemini-3-flash)
GOOGLE_API_KEY=

# Anthropic (claude-3-5-sonnet, claude-4-sonnet)
ANTHROPIC_API_KEY=

# Ollama (local/self-hosted or Ollama Cloud)
# Native runs: http://localhost:11434/v1
# Docker Compose defaults to http://host.docker.internal:11434/v1 when unset
# Gemma 4 models require Ollama 0.20+ (ollama pull gemma4:e4b)
OLLAMA_BASE_URL=http://localhost:11434/v1
# Optional for Ollama Cloud
OLLAMA_API_KEY=

# Apify - Primary YouTube downloader provider
APIFY_API_TOKEN=

# YouTube metadata provider
# `yt_dlp` keeps the current behavior.
# `youtube_data_api` uses the official YouTube Data API first, then falls back to yt-dlp.
YOUTUBE_METADATA_PROVIDER=yt_dlp

# Preferred key for the YouTube Data API metadata path.
# If omitted, metadata requests fall back to GOOGLE_API_KEY when available.
YOUTUBE_DATA_API_KEY=

# ==============================================
# AI Model Configuration
# ==============================================

# Format: "provider:model-name"
# Self-hosted default: local Ollama (no cloud API key). Install from Settings or:
#   ollama pull llama3.2:3b
# The in-app model selector recommends models for your RAM and can install them.
LLM=ollama:llama3.2:3b
OLLAMA_BASE_URL=http://localhost:11434/v1

# Cloud / hosted examples (set the matching API key above):
# LLM=google-gla:gemini-3-flash-preview
# LLM=openai:gpt-5.2
# LLM=anthropic:claude-4-sonnet
# Recommended local models (picked in-app by RAM): ollama:gemma4:e4b (16 GB), ollama:gemma4:26b (24 GB+)

# Mark stale queued tasks as error after this many seconds
QUEUED_TASK_TIMEOUT_SECONDS=180

# Mark stale processing tasks as error when updated_at is older than this (seconds)
PROCESSING_TASK_TIMEOUT_SECONDS=14400

# Worker concurrency and per-job timeout (quality + render can exceed 3h in Docker)
WORKER_MAX_JOBS=1
WORKER_JOB_TIMEOUT_SECONDS=21600

# Default target resolution requested from the Apify YouTube downloader
APIFY_YOUTUBE_DEFAULT_QUALITY=1080

# Processing defaults (quality-first for local M2 Air)
DEFAULT_PROCESSING_MODE=quality
DEFAULT_CAPTION_TEMPLATE=riverside
FAST_MODE_MAX_CLIPS=4
BALANCED_MODE_MAX_CLIPS=7
QUALITY_MODE_MAX_CLIPS=14
QUALITY_MODE_MAX_MICRO=8
QUALITY_MODE_MAX_DEEP=6
FAST_MODE_TRANSCRIPT_MODEL=nano
TRANSCRIPT_WINDOW_SECONDS=300
TRANSCRIPT_WINDOW_OVERLAP=30
ANALYSIS_MAX_WINDOWS=12
LOCAL_LLM_CONCURRENCY=1
MICRO_PER_WINDOW=3
DEEP_PER_WINDOW=2
OLLAMA_NUM_PREDICT=4096

# Frontend defaults (optional)
NEXT_PUBLIC_DEFAULT_PROCESSING_MODE=quality
NEXT_PUBLIC_DEFAULT_CAPTION_TEMPLATE=riverside

# ==============================================
# Authentication
# ==============================================

# Better Auth secret (change this in production!)
# Generate a secure random string for production
BETTER_AUTH_SECRET=supoclip_dev_secret_change_in_production

# Set to true/1/yes to disable new user sign-ups.
DISABLE_SIGN_UP=false

# Local single-user mode (default on): skip sign-in and auto-use one local user.
# Set to false only if you want multi-user email/password auth.
LOCAL_SINGLE_USER=true
NEXT_PUBLIC_LOCAL_SINGLE_USER=true

# Set to true to disable all routes except the landing page.
NEXT_PUBLIC_LANDING_ONLY_MODE=false

# ==============================================
# Analytics (optional)
# ==============================================

# DataFast public website ID (example: dfid_xxxxxx)
NEXT_PUBLIC_DATAFAST_WEBSITE_ID=

# DataFast tracked domain without protocol (example: supoclip.com)
NEXT_PUBLIC_DATAFAST_DOMAIN=

# Set to true only when you want to test DataFast on localhost
NEXT_PUBLIC_DATAFAST_ALLOW_LOCALHOST=false

NEXT_PUBLIC_APP_URL=http://localhost:3000

# ==============================================
# Backend request signing (optional hardening)
# ==============================================

# When set, the backend requires HMAC-signed user-id headers and the
# frontend signs requests with the same secret. Leave empty for the
# default trusted local setup.
BACKEND_AUTH_SECRET=
AUTH_SIGNATURE_TTL_SECONDS=300
CORS_ORIGINS=http://localhost:3000,http://sp.localhost:3000

# ==============================================
# Feedback (optional — posts to Discord)
# ==============================================

DISCORD_FEEDBACK_WEBHOOK_URL=

# ==============================================
# Database Configuration
# ==============================================

# PostgreSQL credentials (matches docker-compose.yml)
POSTGRES_DB=supoclip
POSTGRES_USER=supoclip
POSTGRES_PASSWORD=supoclip_password

# Redis password for Docker/local development.
# Leave blank to run Redis without AUTH, or set a value to require authentication.
REDIS_PASSWORD=

# ==============================================
# Docker Performance
# ==============================================

# Enable BuildKit for faster Docker builds
COMPOSE_DOCKER_CLI_BUILD=1
DOCKER_BUILDKIT=1
